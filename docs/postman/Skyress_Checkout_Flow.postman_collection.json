        { "name": "Create Tag (Admin)", "request": { "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] }, "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Postman Tag\",\n  \"type\": 0\n}" }, "url": "{{baseUrl}}/api/tags?api-version={{apiVersion}}" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
          "if (pm.response.code >= 200 && pm.response.code < 300) { const json = pm.response.json(); pm.collectionVariables.set('tagId', json.id || json.Id); }"
