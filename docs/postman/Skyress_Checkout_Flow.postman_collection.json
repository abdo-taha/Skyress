        { "name": "Update Tag Type (Admin)", "request": { "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] }, "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"type\": 0\n}" }, "url": "{{baseUrl}}/api/tags/{{tagId}}/type?api-version={{apiVersion}}" } },
        { "name": "Delete Tag (Admin)", "request": { "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] }, "method": "DELETE", "url": "{{baseUrl}}/api/tags/{{tagId}}?api-version={{apiVersion}}" } }
      ]
    },
    {
      "name": "07 - Tag Assignments",
      "item": [
        { "name": "Get Assignments By Item", "request": { "method": "GET", "url": "{{baseUrl}}/api/tagAssignments/item/{{itemId}}?api-version={{apiVersion}}" } },
        { "name": "Get Assignments By Tag", "request": { "method": "GET", "url": "{{baseUrl}}/api/tagAssignments/tag/{{tagId}}?api-version={{apiVersion}}" } },
        { "name": "Create Tag Assignment (Admin)", "request": { "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] }, "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"tagId\": {{tagId}},\n  \"itemId\": {{itemId}}\n}" }, "url": "{{baseUrl}}/api/tagAssignments?api-version={{apiVersion}}" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
          "if (pm.response.code >= 200 && pm.response.code < 300) { const json = pm.response.json(); pm.collectionVariables.set('tagAssignmentId', json.id || json.Id); }"
        ] } }] },
        { "name": "Delete Tag Assignment (Admin)", "request": { "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] }, "method": "DELETE", "url": "{{baseUrl}}/api/tagAssignments/{{tagAssignmentId}}?api-version={{apiVersion}}" } }
      ]
    },
    {
      "name": "08 - Todos",
      "item": [
        { "name": "Get All Todos", "request": { "method": "GET", "url": "{{baseUrl}}/api/todos?api-version={{apiVersion}}" } },
        { "name": "Get Todo By Id", "request": { "method": "GET", "url": "{{baseUrl}}/api/todos/{{todoId}}?api-version={{apiVersion}}" } },
        { "name": "Get Todos By State", "request": { "method": "GET", "url": "{{baseUrl}}/api/todos/state/0?api-version={{apiVersion}}" } },
        { "name": "Create Todo", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"context\": \"Postman todo\"\n}" }, "url": "{{baseUrl}}/api/todos?api-version={{apiVersion}}" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
          "if (pm.response.code >= 200 && pm.response.code < 300) { const json = pm.response.json(); pm.collectionVariables.set('todoId', json.id || json.Id); }"
        ] } }] },
        { "name": "Update Todo State", "request": { "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"state\": 1\n}" }, "url": "{{baseUrl}}/api/todos/{{todoId}}/state?api-version={{apiVersion}}" } },
        { "name": "Update Todo Context", "request": { "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"context\": \"Updated Postman todo\"\n}" }, "url": "{{baseUrl}}/api/todos/{{todoId}}/context?api-version={{apiVersion}}" } },
        { "name": "Delete Todo", "request": { "method": "DELETE", "url": "{{baseUrl}}/api/todos/{{todoId}}?api-version={{apiVersion}}" } }
      ]
    },
    {
      "name": "09 - Checkout Flow Runner",
      "description": "Run these in order after Login Admin. Retry invoice/payment lookups because saga processing is asynchronous.",
      "item": [
        { "name": "1. Create Item (Admin)", "request": { "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] }, "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Checkout Flow Item\",\n  \"description\": \"Item created for checkout flow test\",\n  \"price\": 49.50,\n  \"unit\": 0,\n  \"quantityLeft\": 25,\n  \"costPrice\": 20.00,\n  \"qrCode\": \"CHECKOUT-FLOW-ITEM\"\n}" }, "url": "{{baseUrl}}/api/items?api-version={{apiVersion}}" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
          "if (pm.response.code >= 200 && pm.response.code < 300) { const json = pm.response.json(); pm.collectionVariables.set('itemId', json.id || json.Id); }"
        ] } }] },
        { "name": "2. Create Customer (Admin)", "request": { "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] }, "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Checkout Flow Customer\",\n  \"notes\": \"Created for checkout flow\",\n  \"state\": 0\n}" }, "url": "{{baseUrl}}/api/customers?api-version={{apiVersion}}" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
          "if (pm.response.code >= 200 && pm.response.code < 300) { const json = pm.response.json(); pm.collectionVariables.set('customerId', json.id || json.Id); }"
        ] } }] },
        { "name": "3. Create Basket", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"customerId\": {{customerId}}\n}" }, "url": "{{baseUrl}}/api/baskets?api-version={{apiVersion}}" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
          "if (pm.response.code >= 200 && pm.response.code < 300) { const json = pm.response.json(); pm.collectionVariables.set('basketId', json.id || json.Id); }"
        ] } }] },
        { "name": "4. Add Item To Basket", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"itemId\": {{itemId}},\n  \"quantity\": {{quantity}}\n}" }, "url": "{{baseUrl}}/api/baskets/{{basketId}}/items?api-version={{apiVersion}}" } },
        { "name": "5. Initiate Checkout", "request": { "method": "POST", "url": "{{baseUrl}}/api/baskets/initiate-checkout?basketId={{basketId}}&api-version={{apiVersion}}" } },
        { "name": "6. Find Invoice By Customer (Admin, retry)", "request": { "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] }, "method": "GET", "url": "{{baseUrl}}/api/invoices/customer/{{customerId}}?api-version={{apiVersion}}" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
          "if (pm.response.code === 200) { const basketId = String(pm.collectionVariables.get('basketId')); const list = pm.response.json(); const invoice = Array.isArray(list) ? list.find(x => String(x.basketId || x.BasketId) === basketId) : null; if (invoice) { pm.collectionVariables.set('invoiceId', invoice.id || invoice.Id); const paymentId = invoice.paymentId || invoice.PaymentId; if (paymentId) pm.collectionVariables.set('paymentId', paymentId); } }"
        ] } }] },
        { "name": "7. Get Invoice With Payments (Admin, retry)", "request": { "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] }, "method": "GET", "url": "{{baseUrl}}/api/invoices/{{invoiceId}}/withPayments?api-version={{apiVersion}}" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
          "if (pm.response.code === 200) { const json = pm.response.json(); const payments = json.payments || json.Payments || []; const payment = payments[0]; if (payment) { pm.collectionVariables.set('paymentId', payment.id || payment.Id); pm.collectionVariables.set('totalDue', payment.totalDue || payment.TotalDue); } }"
        ] } }] },
        { "name": "8. Complete Cash Payment (Admin)", "request": { "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] }, "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"amount\": {{totalDue}}\n}" }, "url": "{{baseUrl}}/api/payments/{{paymentId}}/Pay?api-version={{apiVersion}}" } },
        { "name": "9. Verify Basket Checked Out (retry)", "request": { "method": "GET", "url": "{{baseUrl}}/api/baskets/{{basketId}}?api-version={{apiVersion}}" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
          "pm.test('basket loaded', function () { pm.response.to.have.status(200); });",
          "const json = pm.response.json(); const state = json.state ?? json.State; pm.test('basket state is CheckedOut when saga is complete', function () { pm.expect(state).to.eql(2); });"
        ] } }] }
      ]
    }
  ]
}
